<!DOCTYPE html>
<html lang="{{ site.language }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Redirecionando — {{ site.name }}</title>
<meta name="description" content="Redirecionamento para a URL atual da página no site {{ site.name }}.">
<meta http-equiv="refresh" content="0; url={{ redirectTo }}">
<meta name="robots" content="noindex">
<link rel="canonical" href="{{ redirectTo | absoluteUrl(site) }}">
</head>
<body>
<p>Redirecionando para <a href="{{ redirectTo }}">{{ redirectTo }}</a>.</p>
</body>
</html>
