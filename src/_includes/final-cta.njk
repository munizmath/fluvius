<section class="section cta-band">
  <div class="wrap cta-band__inner">
    <span class="eyebrow eyebrow--center">Próximo passo</span>
    <h2>{{ ctaTitle or "Converse com a Fluvius sobre seu escopo." }}</h2>
    <p>{{ ctaText or "Envie setor, localização, prazo desejado e documentos existentes. A resposta técnica fica mais objetiva com esse contexto." }}</p>
    <div class="cta-band__btns">
      <a href="{{ '/contato/' | pathUrl(site) }}" class="btn btn--green btn--lg">Solicitar proposta</a>
      <a href="{{ site.contact.whatsappUrl }}" class="btn btn--light btn--lg" target="_blank" rel="noopener">WhatsApp</a>
    </div>
  </div>
</section>
