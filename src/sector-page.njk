---
layout: base.njk
pagination:
  data: sectors
  size: 1
  alias: sector
permalink: "/setores/{{ sector.id }}/index.html"
navKey: portfolio
eleventyComputed:
  title: "{{ sector.title }} — Fluvius Engenharia"
  description: "{{ sector.summary }}"
  breadcrumbs:
    - label: "Setores"
      url: "/portfolio/"
    - label: "{{ sector.title }}"
---
<section class="page-hero">
  <div class="wrap page-hero__inner">
    <span class="eyebrow">Setor atendido</span>
    <h1>{{ sector.title }}</h1>
    <p class="lead">{{ sector.summary }}</p>
    <div class="hero__cta">
      <a href="{{ '/contato/' | pathUrl(site) }}" class="btn btn--green btn--lg">Solicitar proposta</a>
      <a href="{{ '/portfolio/' | pathUrl(site) }}" class="btn btn--light btn--lg">Ver projetos</a>
    </div>
  </div>
</section>
<section class="section bg-paper">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow">Serviços relacionados</span>
      <h2>Frentes técnicas aplicáveis</h2>
    </div>
    <div class="grid grid-3 mt-40">
      {% for service in services %}
      {% if service.sectorTags.includes(sector.id) %}
      <article class="card">
        <h3>{{ service.title }}</h3>
        <p>{{ service.summary }}</p>
        <a class="textlink mt-24" href="{{ ('/servicos/' + service.id + '/') | pathUrl(site) }}">Ver serviço</a>
      </article>
      {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
